// nextflow.config
// Minimal, profile-driven configuration. Use `-profile conda` for a
// reproducible environment, or `-profile local` for an existing env.

manifest {
    name            = 'spatial_visium_nf'
    author          = 'Naraen Palanikumar'
    description     = 'Spatial transcriptomics: 10x Visium + scRNA-seq reference -> per-spot NNLS deconvolution + spatially variable genes'
    version         = '0.1.0'
    nextflowVersion = '>=23.04.0'
}

params {
    outdir       = "${projectDir}/results"
    spatial_h5   = "${projectDir}/data/demo/spatial/filtered_feature_bc_matrix.h5"
    spatial_pos  = "${projectDir}/data/demo/spatial/spatial/tissue_positions_list.csv"
    ref_dir      = "${projectDir}/data/demo/reference"
    ref_meta     = "${projectDir}/data/demo/reference/metadata.csv"
    celltype_col = "cell_type"
    truth        = "${projectDir}/data/demo/truth/proportions.csv"
    n_hvg        = 2000
    knn          = 6
    nperm        = 100
    topn         = 6
    seed         = 42
    tol          = 0.12
}

process {
    executor = 'local'
    cpus     = 2
    memory   = '4 GB'
    cache    = 'lenient'
}

profiles {
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/envs/spatial_visium_env.yml"
    }
    local {
        // Assume the env + bin/ scripts are already on PATH.
    }
}

env {
    PYTHONNOUSERSITE = "1"
}
