// nextflow.config
// Minimal, profile-driven configuration. Use `-profile conda` for a
// reproducible environment, or `-profile local` for an existing env.

manifest {
    name            = 'aml_rnaseq_nf'
    author          = 'Naraen Palanikumar'
    description     = 'Mini bulk RNA-seq DE pipeline (AML vs. healthy)'
    version         = '0.2.0'
    nextflowVersion = '>=23.04.0'
}

params {
    outdir       = "${projectDir}/results"
    n_per_group  = 50
    seed         = 42
    fdr          = 0.05
    lfc          = 1.0
}

process {
    executor  = 'local'
    cpus      = 1
    memory    = '2 GB'
    cache     = 'lenient'
}

profiles {
    conda {
        conda.enabled    = true
        process.conda    = "${projectDir}/envs/aml_rnaseq_env.yml"
    }
    local {
        // Assume scripts in bin/ are already runnable on PATH.
    }
}

env {
    PYTHONNOUSERSITE = "1"
}
