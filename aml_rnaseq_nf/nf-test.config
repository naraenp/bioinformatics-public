// nf-test configuration for aml_rnaseq_nf.
//
// This is a STARTER scaffold for migrating the smoke checks to nf-test
// (the modern Nextflow testing standard). The fast, data-free pytest suite in
// tests/test_de.py remains the primary CI gate; nf-test is added alongside it,
// not as a replacement. Run with the conda env active (provides nextflow +
// the bin/ deps), after `npm i -g @nf-core/nf-test` or the nf-test installer:
//
//     nf-test test
config {
    testsDir "tests"
    workDir  ".nf-test"
    configFile "nextflow.config"
    profile "local"
}
