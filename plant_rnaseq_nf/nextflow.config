// nextflow.config
// Minimal, profile-driven configuration. Use `-profile conda` for a
// reproducible environment, or `-profile local` for an existing env.

manifest {
    name            = 'plant_rnaseq_nf'
    author          = 'Naraen Palanikumar'
    description     = 'Plant RNA-seq DE pipeline: raw reads -> alignment -> DE -> GO enrichment (tolerant vs. susceptible)'
    version         = '0.1.0'
    nextflowVersion = '>=23.04.0'
}

params {
    outdir      = "${projectDir}/results"
    samplesheet = "${projectDir}/data/samplesheet.csv"
    genome      = "${projectDir}/data/genome.fa"
    gtf         = "${projectDir}/data/genes.gtf"
    gmt         = "${projectDir}/data/go_sets.gmt"
    subsample   = 0
    seed        = 42
    fdr         = 0.05
    lfc         = 1.0
    topn        = 40
    design      = "~genotype"
    tolerant    = "tolerant"
    susceptible = "susceptible"
}

process {
    executor = 'local'
    cpus     = 2
    memory   = '4 GB'
    cache    = 'lenient'
}

profiles {
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/envs/plant_rnaseq_env.yml"
    }
    local {
        // Assume the toolchain + bin/ scripts are already on PATH.
    }
}

env {
    PYTHONNOUSERSITE = "1"
}
