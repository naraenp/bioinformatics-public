// nextflow.config
// Minimal, profile-driven configuration. Use `-profile conda` for a
// reproducible environment, or `-profile local` for an existing env.

manifest {
    name            = 'variant_calling_nf'
    author          = 'Naraen Palanikumar'
    description     = 'Germline short-variant pipeline: raw reads -> BWA-MEM -> GATK HaplotypeCaller joint genotyping -> hard-filter -> consequence annotation'
    version         = '0.1.0'
    nextflowVersion = '>=23.04.0'
}

params {
    outdir      = "${projectDir}/results"
    samplesheet = "${projectDir}/data/samplesheet.csv"
    genome      = "${projectDir}/data/genome.fa"
    gtf         = "${projectDir}/data/genes.gtf"
    intervals   = ""           // optional BED to restrict calling (real GIAB run)
    subsample   = 0            // read pairs per sample; 0 = use all reads
    seed        = 42
    ploidy      = 2
    topn        = 40           // variants shown in the genotype heatmap
}

process {
    executor = 'local'
    cpus     = 2
    memory   = '4 GB'
    cache    = 'lenient'
}

profiles {
    conda {
        conda.enabled = true
        process.conda = "${projectDir}/envs/variant_calling_env.yml"
    }
    docker {
        // Image bakes envs/variant_calling_env.yml — build it with:
        //   docker build -t variant_calling_nf:0.1.0 .
        docker.enabled    = true
        process.container = 'variant_calling_nf:0.1.0'
    }
    singularity {
        // Pulls/uses the same image via Singularity/Apptainer.
        singularity.enabled    = true
        singularity.autoMounts = true
        process.container      = 'docker://variant_calling_nf:0.1.0'
    }
    local {
        // Assume the toolchain + bin/ scripts are already on PATH.
    }
}

env {
    PYTHONNOUSERSITE = "1"
}
